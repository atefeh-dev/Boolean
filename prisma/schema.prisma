// Prisma schema — foundation for سایدبار's backend.
// Run `npx prisma generate` after install, then `npx prisma migrate dev --name init`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum LinkStatus {
  PENDING
  PUBLISHED
  REJECTED
}

model NewsletterSend {
  id            String   @id @default(uuid())
  recipients    Int
  linkCount     Int
  sentAt        DateTime @default(now())

  @@map("newsletter_sends")
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  // Set when the subscribing email belongs to (or is later claimed by) a
  // logged-in account, so subscribed status can follow the account across
  // browsers/devices instead of living in browser storage.
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("subscribers")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Watermark for the notifications bell: anything newer than this is
  // unread. Updated whenever the user opens the notifications panel.
  lastNotificationsReadAt DateTime?

  links       Link[]
  resetTokens PasswordResetToken[]
  dismissedNotifications NotificationDismissal[]
  subscriber  Subscriber?

  @@map("users")
}

// Notifications are derived at read-time from Link rows (see
// /api/notifications) rather than stored — there's no Notification table.
// Dismissing one is therefore just "remember this derived id is hidden for
// this user", so it stays gone across refreshes/devices without needing to
// touch the underlying Link.
model NotificationDismissal {
  id             String   @id @default(uuid())
  userId         String
  notificationId String // e.g. "pending:<linkId>" — matches NotificationItem.id
  dismissedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
  @@map("notification_dismissals")
}

model Category {
  id    String @id // slug, e.g. "ux", "ai" — matches existing frontend ids
  label String

  links Link[]

  @@map("categories")
}

model Link {
  id          String     @id @default(uuid())
  url         String
  title       String
  body        String?
  credit      String?
  status      LinkStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?
  notifiedAt  DateTime?

  submittedBy   User?   @relation(fields: [submittedById], references: [id])
  submittedById String?

  categories Category[]

  @@index([status])
  @@map("links")
}
